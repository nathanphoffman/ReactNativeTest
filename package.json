{
  "name": "react-native-test",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npm run build:pyx && concurrently \"expo start\" \"npm run watch:pyx\"",
    "android": "npm run build:pyx && concurrently \"expo start --android\" \"npm run watch:pyx\"",
    "ios": "npm run build:pyx && concurrently \"expo start --ios\" \"npm run watch:pyx\"",
    "web": "npm run build:pyx && concurrently \"expo start --web\" \"npm run watch:pyx\"",
    "build:pyx": "python3 scripts/build_pyx.py",
    "watch:pyx": "chokidar \"components/**/*.pyx\" -c \"python3 scripts/build_pyx.py {path}\"",
    "setup:pyx": "pip install transcrypt"
  },
  "dependencies": {
    "expo": "~56.0.0",
    "expo-constants": "~56.0.0",
    "expo-linking": "~56.0.0",
    "expo-router": "~56.2.0",
    "expo-splash-screen": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "nativewind": "^4.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.85.0",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "^19.2.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.1",
    "typescript": "^5.3.0"
  }
}
